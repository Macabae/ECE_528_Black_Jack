#include "msp.h"
#include "Camera.h"

void camera_gpio_init(void)
{
    // Data pins as inputs
    P4->SEL0 &= ~0xFE;
    P4->SEL1 &= ~0xFE;
    P4->DIR &= ~0xFE;
    P4->REN &= ~0xFE;

    P5->SEL0 &= ~0x01;
    P5->SEL1 &= ~0x01;
    P5->DIR &= ~0x01;
    P5->REN &= ~0x01;

    // Sync pins as inputs
    P2->SEL0 &= ~0xE0;
    P2->SEL1 &= ~0xE0;
    P2->DIR &= ~0xE0;
    P2->REN &= ~0xE0;

    // Control pins as outputs
    P5->DIR |= 0x06;

    // Normal mode
    P5->OUT |= 0x02;
    P5->OUT &= ~0x04;
    P4->OUT &= ~0x04;
}

uint8_t cam_read_byte(void)
{
    return ((P4->IN >> 1) & 0x7F) | ((P5->IN & 0x01) << 7);
}

void camera_xclk_init(void)
{
    // P2.4 as timer output
    P2->DIR |= 0x10;
    P2->SEL0 |= 0x10;
    P2->SEL1 &= ~0x10;

    // Timer_A0 setup (SMCLK, toggle mode)
    TIMER_A0->CCR[0] = 3;
    TIMER_A0->CCR[1] = 1;
    TIMER_A0->CCTL[1] = TIMER_A_CCTLN_OUTMOD_7;

    TIMER_A0->CTL = TIMER_A_CTL_SSEL__SMCLK | TIMER_A_CTL_MC__UP;
}

void camera_i2c_init(void)
{
    P6->SEL0 |= 0x30;
    P6->SEL1 &= ~0x30;

    EUSCI_B1->CTLW0 = EUSCI_B_CTLW0_SWRST;   // reset peripheral
    EUSCI_B1->IE = 0;
    EUSCI_B1->IFG = 0;

    EUSCI_B1->CTLW0 = EUSCI_B_CTLW0_SWRST |
                      EUSCI_B_CTLW0_MODE_3 |
                      EUSCI_B_CTLW0_MST |
                      EUSCI_B_CTLW0_SYNC |
                      EUSCI_B_CTLW0_SSEL__SMCLK;

    EUSCI_B1->BRW = 30;
    EUSCI_B1->I2CSA = 0x21;

    EUSCI_B1->CTLW0 &= ~EUSCI_B_CTLW0_SWRST;
}

int ov7670_write(uint8_t reg, uint8_t val)
{
    volatile uint32_t timeout = 100000;

    while ((EUSCI_B1->STATW & EUSCI_B_STATW_BBUSY) && --timeout);

    if (timeout == 0)
        return 0;

    EUSCI_B1->I2CSA = 0x21;
    EUSCI_B1->CTLW0 |= EUSCI_B_CTLW0_TR;
    EUSCI_B1->CTLW0 |= EUSCI_B_CTLW0_TXSTT;

    timeout = 100000;
    while (!(EUSCI_B1->IFG & EUSCI_B_IFG_TXIFG0) && --timeout);
    if (timeout == 0)
        return 0;

    EUSCI_B1->TXBUF = reg;

    timeout = 100000;
    while (!(EUSCI_B1->IFG & EUSCI_B_IFG_TXIFG0) && --timeout);
    if (timeout == 0)
        return 0;

    EUSCI_B1->TXBUF = val;

    timeout = 100000;
    while (!(EUSCI_B1->IFG & EUSCI_B_IFG_TXIFG0) && --timeout);
    if (timeout == 0)
        return 0;

    EUSCI_B1->CTLW0 |= EUSCI_B_CTLW0_TXSTP;

    timeout = 100000;
    while ((EUSCI_B1->CTLW0 & EUSCI_B_CTLW0_TXSTP) && --timeout);
    if (timeout == 0)
        return 0;

    return 1;
}

void ov7670_init(void)
{
    // Reset
    ov7670_write(0x12, 0x80);
    volatile int i;
    for (i = 0; i < 100000; i++);

    // RGB mode
    ov7670_write(0x12, 0x04);

    // Clock divide (slow it down)
    ov7670_write(0x11, 0x01);

    // RGB565
    ov7670_write(0x40, 0xD0);

    // TSLB (common setting)
    ov7670_write(0x3A, 0x04);
}

uint8_t ov7670_read(uint8_t reg)
{
    while (EUSCI_B1->STATW & EUSCI_B_STATW_BBUSY);

    EUSCI_B1->I2CSA = 0x21;

    // send register address
    EUSCI_B1->CTLW0 |= EUSCI_B_CTLW0_TR;
    EUSCI_B1->CTLW0 |= EUSCI_B_CTLW0_TXSTT;

    while (!(EUSCI_B1->IFG & EUSCI_B_IFG_TXIFG0));
    EUSCI_B1->TXBUF = reg;

    while (!(EUSCI_B1->IFG & EUSCI_B_IFG_TXIFG0));

    // repeated start, switch to receive
    EUSCI_B1->CTLW0 &= ~EUSCI_B_CTLW0_TR;
    EUSCI_B1->CTLW0 |= EUSCI_B_CTLW0_TXSTT;

    while (EUSCI_B1->CTLW0 & EUSCI_B_CTLW0_TXSTT);

    EUSCI_B1->CTLW0 |= EUSCI_B_CTLW0_TXSTP;

    while (!(EUSCI_B1->IFG & EUSCI_B_IFG_RXIFG0));
    return EUSCI_B1->RXBUF;
}
